# Visitor counter (Upstash Redis)
# Create a free database at https://upstash.com → copy REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Subscribe form + welcome email (Resend)
# Sign up at https://resend.com → API Keys → Create API Key
RESEND_API_KEY=
# Resend → Audiences → create an audience → copy the Audience ID
RESEND_AUDIENCE_ID=
